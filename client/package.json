{
	"name": "client",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write .",
		"lint": "prettier --check . && eslint .",
		"lint:fix": "eslint . --fix",
		"test:unit": "vitest",
		"test": "npm run test:unit -- --run && npm run test:e2e",
		"test:e2e": "playwright test",
		"test:install": "pnpm exec playwright install chromium",
		"api": "pnpm run api:swagger && npm run api:orval",
		"api:swagger": "curl http://localhost:5000/openapi/v1.json > swagger.json",
		"api:orval": "orval"
	},
	"devDependencies": {
		"@eslint/compat": "^2.1.0",
		"@eslint/js": "^10.0.1",
		"@fontsource-variable/inter": "^5.2.8",
		"@internationalized/date": "^3.12.1",
		"@kayord/ui": "^3.0.6",
		"@lucide/svelte": "^1.14.0",
		"@playwright/test": "^1.59.1",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.59.1",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/vite": "^4.3.0",
		"@tanstack/svelte-form": "^1.31.0",
		"@tanstack/svelte-query": "^6.1.28",
		"@tanstack/table-core": "^8.21.3",
		"@vitest/browser": "^4.1.5",
		"@vitest/browser-playwright": "^4.1.5",
		"eslint": "^10.3.0",
		"eslint-config-prettier": "^10.0.1",
		"eslint-plugin-svelte": "^3.17.1",
		"globals": "^17.6.0",
		"jwt-decode": "^4.0.0",
		"layerchart": "2.0.0-next.33",
		"mode-watcher": "^1.1.0",
		"oidc-client-ts": "^3.5.0",
		"orval": "^8.9.1",
		"playwright": "^1.59.1",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^3.5.1",
		"prettier-plugin-tailwindcss": "^0.8.0",
		"runed": "^0.37.1",
		"shadcn-svelte": "^1.2.7",
		"svelte": "^5.55.5",
		"svelte-check": "^4.4.8",
		"svelte-sonner": "^1.1.1",
		"tailwindcss": "^4.3.0",
		"tw-animate-css": "^1.4.0",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.59.2",
		"vite": "^8.0.11",
		"vitest": "^4.1.5",
		"vitest-browser-svelte": "^2.1.1",
		"zod": "^4.4.3"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"@tailwindcss/oxide",
			"esbuild"
		]
	}
}
